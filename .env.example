ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Account system (backend) config — put real values only in your local .env, never commit to Git
# MySQL connection string: mysql+pymysql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=mysql+pymysql://root:your_mysql_password@localhost:3306/polisher
# JWT signing secret: a long random string, generate with `python -c "import secrets; print(secrets.token_urlsafe(48))"`
JWT_SECRET=your_random_secret_here
# Google OAuth Client ID (public value, not a secret) from Google Cloud Console -> OAuth 2.0 Client
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
